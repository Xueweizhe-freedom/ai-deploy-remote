# GitHub API Token (可选)
# 用于提高 API 请求频率限制
# 在 https://github.com/settings/tokens 生成
VITE_GITHUB_TOKEN=your_github_token_here

# Vercel API Token (可选)
# 用于真实部署到 Vercel
# 在 https://vercel.com/account/tokens 生成
VITE_VERCEL_TOKEN=your_vercel_token_here

# Cloudflare Pages API Token (可选)
# 用于真实部署到 Cloudflare Pages（推荐，国内访问最快）
# 在 https://dash.cloudflare.com/profile/api-tokens 生成
# 需要 Zone:Read 和 Cloudflare Pages:Edit 权限
VITE_CLOUDFLARE_TOKEN=your_cloudflare_token_here
VITE_CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# 应用配置
VITE_APP_NAME=AI Deploy
VITE_APP_VERSION=1.0.0
